/**
 * JNI Bridge for {{ class_name }}
 *
 * Auto-generated by ArkProbe Hotspot Accelerator
 * Provides JNI callbacks and native method registration.
 *
 * To compile:
 *   mkdir build && cd build
 *   cmake ..
 *   make
 *
 * To load in Java:
 *   System.load("/path/to/lib{{ library_name }}.so");
 */

#include <jni.h>
#include <string>
#include <iostream>

// Forward declarations of generated implementations
{% for method in methods -%}
extern "C" JNIEXPORT {{ method.return_type }} JNICALL
{{ method.mangled_name }}(
    JNIEnv* env,
    jobject thiz
    {%- for param in method.params %},
    {{ param.jni_type }} {{ param.name }}
    {%- endfor %}
);
{% endfor %}

/**
 * JNI_OnLoad — called when native library is loaded
 */
JNIEXPORT jint JNICALL JNI_OnLoad(JavaVM* vm, void* reserved) {
    JNIEnv* env;
    if (vm->GetEnv((void**)&env, JNI_VERSION_1_8) != JNI_OK) {
        return JNI_ERR;
    }

    // Register native methods
    jclass cls = env->FindClass("{{ class_name }}");
    if (cls == nullptr) {
        std::cerr << "Failed to find class: {{ class_name }}" << std::endl;
        return JNI_ERR;
    }

    JNINativeMethod methods[] = {
{% for method in methods -%}
        {
            "{{ method.method_name }}",
            "{{ method.signature }}",
            (void*){{ method.mangled_name }}
        }{% if not loop.last %},{% endif %}

{% endfor -%}
    };

    jint result = env->RegisterNatives(cls, methods, {{ methods|length }});
    if (result < 0) {
        std::cerr << "Failed to register native methods for {{ class_name }}" << std::endl;
        env->DeleteLocalRef(cls);
        return JNI_ERR;
    }

    env->DeleteLocalRef(cls);

    std::cout << "[ArkProbe] Native library loaded: {{ class_name }}" << std::endl;
    return JNI_VERSION_1_8;
}

/**
 * JNI_OnUnload — called when native library is unloaded
 */
JNIEXPORT void JNICALL JNI_OnUnload(JavaVM* vm, void* reserved) {
    JNIEnv* env;
    if (vm->GetEnv((void**)&env, JNI_VERSION_1_8) == JNI_OK) {
        std::cout << "[ArkProbe] Native library unloaded: {{ class_name }}" << std::endl;
    }
}
